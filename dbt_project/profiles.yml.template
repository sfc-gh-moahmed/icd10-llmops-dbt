# Snowflake Connection Profile Template
# Rename this file to profiles.yml and fill in your credentials

icd10_llmops:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: YOUR_ACCOUNT_LOCATOR    # e.g., xy12345.us-east-1
      user: YOUR_USERNAME
      authenticator: externalbrowser   # or 'snowflake' for password auth
      # password: YOUR_PASSWORD        # Uncomment if using password auth
      role: YOUR_ROLE                  # e.g., ACCOUNTADMIN or custom role
      warehouse: YOUR_WAREHOUSE        # e.g., COMPUTE_WH
      database: YOUR_DATABASE          # e.g., ANALYTICS_DB
      schema: YOUR_SCHEMA              # e.g., ICD10_DEMO
      threads: 4
